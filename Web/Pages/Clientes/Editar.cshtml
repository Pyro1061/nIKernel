@page 
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model nIKernel.Pages.Clientes.EditarModel
@{
    ViewData["Title"]= "Editar Cliente";
}
<br>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-plus"></i> Editar Cliente</h2>
    <a asp-page="/Clientes/Index" class="btn btn-outline-secondary">Voltar</a>
</div>


<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">

            <input type="hidden" asp-for="Cliente.CL_id" />
            <input type="hidden" asp-for="Cliente.CL_data_inclusao" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_nome" class="form-label fw-bold">Nome Completo</label>
                    <input asp-for="Cliente.CL_nome" class="form-control"/>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_apelido" class="form-label fw-bold">Apelido</label>
                    <input asp-for="Cliente.CL_apelido" class="form-control"/>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Cliente.CL_status" class="form-label fw-bold" >Status</label>
                    <select asp-for="Cliente.CL_status" class="form-control">
                        <option value="A">Ativo</option>
                        <option value="I">Inativo</option>
                        <option value="B">Bloqueado</option>
                    </select>
                </div>
            </div>
            <div class="row">
                 <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_cpf_cnpj" class="form-label fw-bold">CPF/CNPJ</label>
                    <input asp-for="Cliente.CL_cpf_cnpj" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_rg_ie" class="form-label fw-bold">RG/IE</label>
                    <input asp-for="Cliente.CL_rg_ie" class="form-control"/>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-primary px-5"> Salvar Alterações</button>
            </div>

            <button type="submit"
                asp-page-handler="Deletar"
                asp-route-id="@Model.Cliente.CL_id"
                class="btn btn-danger"
                onclick="return confirm('Tem certeza que deseja deletar este cliente?');">
                Deletar
            </button>
        </form>
    </div>
</div>