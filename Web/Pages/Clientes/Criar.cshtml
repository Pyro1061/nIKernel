@page
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model nIKernel.Pages.Clientes.CriarModel;
@{
    ViewData["Title"]= "Novo Cliente";
}

<br>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-plus"></i> Novo Cliente</h2>
    <a asp-page="/Clientes/Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_nome" class="form-label fw-bold">Nome Completo</label>
                    <input asp-for="Cliente.CL_nome" class="form-control" />
                    <span asp-validation-for="Cliente.CL_nome" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_apelido" class="form-label fw-bold">Apelido</label>
                    <input asp-for="Cliente.CL_apelido" class="form-control" />
                    <span asp-validation-for="Cliente.CL_apelido" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Cliente.CL_status" class="form-label fw-bold">Status</label>
                    <select asp-for="Cliente.CL_status" class="form-select"> 
                        <option value="A">Ativo</option>
                        <option value="I">Inativo</option>
                        <option value="B">Bloqueado</option>
                    </select>
                </div>
            </div>

            <div class="row border-bottom pb-3 mb-3">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_cpf_cnpj" class="form-label fw-bold">CPF/CNPJ</label>
                    <input asp-for="Cliente.CL_cpf_cnpj" class="form-control" />
                    <span asp-validation-for="Cliente.CL_cpf_cnpj" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Cliente.CL_rg_ie" class="form-label fw-bold">RG/IE</label>
                    <input asp-for="Cliente.CL_rg_ie" class="form-control" />
                    <span asp-validation-for="Cliente.CL_rg_ie" class="text-danger small"></span>
                </div>
            </div>

            <label class="form-label text-muted">Endereço do Cliente</label>
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="Cliente.END_LOG" class="form-label fw-bold">Logradouro</label>
                    <input asp-for="Cliente.END_LOG" class="form-control"/>
                    <span asp-validation-for="Cliente.END_LOG" class="text-danger small"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Cliente.END_CEP" class="form-label fw-bold">CEP</label>
                    <input asp-for="Cliente.END_CEP" class="form-control" />
                    <span asp-validation-for="Cliente.END_CEP" class="text-danger small"></span>
                </div>
                <div class="col-md-2 mb-2">
                    <label asp-for="Cliente.END_NUM" class="form-label fw-bold">Número</label>
                    <input asp-for="Cliente.END_NUM" class="form-control"/>
                    <span asp-validation-for="Cliente.END_NUM" class="text-danger small"></span>
                </div>
                <div class="col-md-2 mb-2">
                    <label asp-for="Cliente.END_EST" class="form-label fw-bold">Estado</label>
                    <input asp-for="Cliente.END_EST" class="form-control"/>
                    <span asp-validation-for="Cliente.END_EST" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-2">
                    <label asp-for="Cliente.END_BAI" class="form-label fw-bold">Bairro</label>
                    <input asp-for="Cliente.END_BAI" class="form-control"/>
                    <span asp-validation-for="Cliente.END_BAI" class="text-danger small"></span>
                </div>
                 <div class="col-md-4 mb-3">
                    <label asp-for="Cliente.END_CPL" class="form-label fw-bold">Complemento</label>
                    <input asp-for="Cliente.END_CPL" class="form-control" />
                    <span asp-validation-for="Cliente.END_CPL" class="text-danger small"></span>
                </div>
                
                <div class="col-md-3 mb-3">
                    <label asp-for="Cliente.END_CID" class="form-label fw-bold">Cidade</label>
                    <input asp-for="Cliente.END_CID" class="form-control"/>
                    <span asp-validation-for="Cliente.END_CID" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="btn btn-primary px-5">Salvar Cliente</button>
            </div>
        </form>

        
    </div>
</div>