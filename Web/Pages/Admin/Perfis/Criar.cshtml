@page
@model nIKernel.Pages.Admin.Perfis.CriarModel;
@{
    ViewData["Title"] = "Novo Perfil";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plus-circle"></i> Novo Perfil</h2>
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Perfil.PRF_DSC" class="form-label fw-bold"> Descrição do Perfil</label>
                    <input asp-for="Perfil.PRF_DSC" class="form-control" plceholder="Ex: Operador de Caixa" required>
                </div>
 
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PRF_STA" class="form-label fw-bold"> Status Inicial</label>
                    <select asp-for="Perfil.PRF_STA" class="form-select" required>
                        <option value="A">Ativo</option>
                        <option value="I">Inativo</option>
                    </select>
                </div>
            </div>

            <hr class="text-muted" />

            <div class="text-muted">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-check-lg"></i> Salvar Perfil
                </button> 
            </div>
        </form>
    </div>
</div>