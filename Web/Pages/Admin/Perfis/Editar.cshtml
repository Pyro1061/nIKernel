@page "{id:int}"
@model nIKernel.Pages.Admin.Perfis.EditarModel;
@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="d-flex justify-content-detween align-items-center mb-4">
    <h2><i class="bi bi-pencil-square"></i> Editar Perfil</h2>
    <a asp-page="./Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
</div>

<div class="card shadow-sm border-primary border-top border-3">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Perfil.PRF_ID" />

            <div class="row border-bottom pb-3 mb-3">
                <div class="col-md-2">
                    <label class="form-label text-muted">ID do Perfil</label>
                    <input class="form-control bg-light" value="@Model.Perfil.PRF_ID" disabled />
                </div>
                <div class="col-md-10 d-flex align-items-end">
                    <p class="text-muted mb-2 small"><i class="bi bi-info-circle"></i> O número de identificação do perfil não pode ser alterado.</p>
                </div>
            </div>
            <div class="row">
                <div class="col-md-8 ,b-3">
                    <label asp-for="Perfil.PRF_DSC" class="form-label fw-bold">Descrição do Perfil</label>
                    <input asp-for="Perfil.PRF_DSC" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PRF_STA" class="form-label fw-bold">Status</label>
                    <select asp-for="Perfil.PRF_STA" class="form-select">
                        <option value="A">Ativo</option>
                        <option value="I">Inativo</option>
                    </select>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save">Salvar Alterações</i>
                </button>
            </div>
        </form>
    </div>

</div>