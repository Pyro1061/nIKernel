@page
@model nIKernel.Pages.Login.IndexModel
@{
    // Remocemos o layout padrão (menu, rodapé) para a tela de login ficar isolada
    Layout = null;
    ViewData["Title"] = "nIKernel - Acesso ao Sistema";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card shadow-sm border=0 rounded-lg mt-5">
                    <div class="card-header bg-dark text-white text-center py-4">
                        <h3 class="font-weight-light my-2">nIKernel</h3>
                        <small>AcessoRestrito</small>
                    </div>
                    <div class="cardy-body p-4">
                        @if (!ModelState.IsValid) {
                            <div class="alert alert-danger" role="alert">
                                <div asp-validation-summary="All" class="text-danger mb-0"></div>
                            </div>
                        }

                        <form method="post">
                            <div class="form-floating mb-3"> 
                                <input asp-for="Input.Usuario" class="form-control" id="inputUsuario" placeholder="Seu usuário ou e-mail" autofocus />
                                <label for="inputUsuario">Usuário ou E-mail</label>
                                <span asp-validataion-for="Input.Usuario" class="text-danger"></span>
                            </div>
                            <div class="form-floating mb-4"> 
                                <input asp-for="Input.Senha" class="form-control" id="inputSenha" placeholder="Sua senha" />
                                <label for="inputSenha">Senha</label>
                                <span asp-validataion-for="Input.Senha" class="text-danger"></span>
                            </div>
                            <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                                <button type="submit" class="btn btn-primary w-100 py-2"> Entrar no Sistema</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>