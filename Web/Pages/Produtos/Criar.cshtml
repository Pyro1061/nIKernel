@page
@model Web.Pages.Admin.Produtos.CriarModel
@{
    ViewData["Title"] = "Novo Produto";
}

<h1>Novo Produto</h1>
<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Produto.prd_cod"></label>
                <input asp-for="Produto.prd_cod" class="form-control" placeholder="Código interno" />
                <span asp-validation-for="Produto.prd_cod" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Produto.prd_gtin_ean"></label>
                <input asp-for="Produto.prd_gtin_ean" class="form-control" maxlength="14" placeholder="Somente dígitos" />
                <span asp-validation-for="Produto.prd_gtin_ean" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group">
        <label asp-for="Produto.prd_descricao"></label>
        <input asp-for="Produto.prd_descricao" class="form-control" placeholder="Descrição do produto" />
        <span asp-validation-for="Produto.prd_descricao" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="Produto.prd_un_compra"></label>
                <select asp-for="Produto.prd_un_compra" class="form-control">
                    <option value="UN">Unidade</option>
                    <option value="CX">Caixa</option>
                    <option value="KG">Quilo</option>
                    <option value="G">Grama</option>
                    <option value="LT">Litro</option>
                </select>
                <span asp-validation-for="Produto.prd_un_compra" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="Produto.prd_un_venda"></label>
                <select asp-for="Produto.prd_un_venda" class="form-control">
                    <option value="UN">Unidade</option>
                    <option value="CX">Caixa</option>
                    <option value="KG">Quilo</option>
                    <option value="G">Grama</option>
                    <option value="LT">Litro</option>
                </select>
                <span asp-validation-for="Produto.prd_un_venda" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="Produto.prd_preco_compra"></label>
                <input asp-for="Produto.prd_preco_compra" class="form-control" type="number" step="0.01" min="0" />
                <small class="form-text text-muted">Use ponto para decimais.</small>
                <span asp-validation-for="Produto.prd_preco_compra" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Produto.prd_margem_venda">Margem de Lucro (%)</label>
                <input asp-for="Produto.prd_margem_venda" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Produto.prd_margem_venda" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Produto.prd_ativo"></label>
                <select asp-for="Produto.prd_ativo" class="form-control">
                    <option value="S">Sim</option>
                    <option value="N">Não</option>
                </select>
                <span asp-validation-for="Produto.prd_ativo" class="text-danger"></span>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
