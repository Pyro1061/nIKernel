@page
@model nIKernel.Pages.Fornecedor.IndexModel
@{
    ViewData["Title"] = "Gestão de Fornecedores";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Fornecedores</h2>
        <a asp-page="Criar" class="btn btn-primary">Adicionar Novo</a>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nome Fantasia</th>
                <th>CNPJ</th>
                <th>E-mail</th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.ListaFornecedores)
            {
                <tr>
                    <td>@item.NomeFantasia</td>
                    <td>@item.Cnpj</td>
                    <td>@item.Email</td>
                    <td class="text-center">
                        <a asp-page="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">Editar</a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir este fornecedor?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>